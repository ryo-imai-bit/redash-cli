# Redash CLI Configuration
# Copy this file to .env and fill in your values

# Required: Redash instance URL
REDASH_URL=https://redash.example.com

# Required: Your Redash API key (found in User Settings)
REDASH_API_KEY=your_api_key_here

# Optional: Request timeout in milliseconds (default: 30000)
# REDASH_TIMEOUT=30000

# Optional: Maximum number of results to fetch (default: 1000)
# REDASH_MAX_RESULTS=1000

# Optional: SOCKS proxy URL
# REDASH_SOCKS_PROXY=socks5://localhost:1080

# Optional: Extra headers as JSON or key=value;key=value format
# REDASH_EXTRA_HEADERS={"Authorization": "Bearer token"}
# REDASH_EXTRA_HEADERS=X-Custom-Header=value;X-Another=value2

# Optional: Profile name to use from config file
# REDASH_PROFILE=prod
